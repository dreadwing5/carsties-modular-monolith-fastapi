{
  "realm": "carsties",
  "enabled": true,
  "registrationAllowed": true,
  "accessTokenLifespan": 3600,
  "clientScopes": [
    {
      "name": "auctionApp",
      "description": "Auction app full access",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "profile",
      "description": "OpenID Connect profile scope (username claim)",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "postman",
      "name": "Postman",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "NotASecret",
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["https://www.getpostman.com/oauth2/callback"],
      "defaultClientScopes": ["profile", "auctionApp"],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@carsties.local",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Smith",
      "credentials": [{ "type": "password", "value": "Pass123$", "temporary": false }]
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@carsties.local",
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Smith",
      "credentials": [{ "type": "password", "value": "Pass123$", "temporary": false }]
    },
    {
      "username": "tom",
      "enabled": true,
      "email": "tom@carsties.local",
      "emailVerified": true,
      "firstName": "Tom",
      "lastName": "Smith",
      "credentials": [{ "type": "password", "value": "Pass123$", "temporary": false }]
    }
  ]
}
