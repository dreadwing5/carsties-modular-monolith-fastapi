# Copy to .env to override defaults (all optional — defaults match docker-compose.yml)

CARSTIES_DATABASE_URL=postgresql+asyncpg://postgres:postgrespw@localhost:5433/auctions
CARSTIES_MONGODB_URL=mongodb://localhost:27017
CARSTIES_MONGODB_DATABASE=search_db
CARSTIES_IDENTITY_SERVER_URL=http://localhost:5001/realms/carsties
CARSTIES_OUTBOX_POLL_INTERVAL_SECONDS=10
CARSTIES_SEED_DATABASE=true
